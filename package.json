{
  "name": "changed-files",
  "version": "1.0.0",
  "description": "A Faster Github Action to filter for changed files",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "biome format --write .",
    "format-check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run check && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Cody Lee",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.6.2",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.4.2",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
